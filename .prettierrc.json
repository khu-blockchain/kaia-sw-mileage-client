{
	"trailingComma": "all",
	"tabWidth": 2,
	"useTabs": true,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"semi": true,
	"plugins": ["@ianvs/prettier-plugin-sort-imports"],
	"importOrder": [
		"<TYPES>^(node:)",
		"<TYPES>",
		"<TYPES>^[.]",
		"",
		"<BUILTIN_MODULES>",
		"",
		"^(react/(.*)$)|^(react$)",
		"",
		"<THIRD_PARTY_MODULES>",
		"",
		"^@app/(.*)$",
		"^@pages/(.*)$",
		"^@widgets/(.*)$",
		"^@features/(.*)$",
		"^@entities/(.*)$",
		"^@shared/(.*)$",
		"^@/(.*)$",
		"",
		"^(?!.*[.]css$)[./].*$",
		".css$"
	],
	"importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
	"importOrderTypeScriptVersion": "5.8.0",
	"importOrderCaseSensitive": false
}
